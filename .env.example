# ASP.NET Core environment state
ASPNETCORE_ENVIRONMENT=Development

# JWT Config (para firmas de tokens legacy)
JWT_KEY=your_jwt_signing_key_32_chars
JWT_ISSUER=ElohimShop
JWT_AUDIENCE=ElohimShopAPI

# Provisionamiento de Super Admin (se crea al iniciar si no existe en la BD)
SUPER_ADMIN_EMAIL=superadmin@elohim.gt
SUPER_ADMIN_PASSWORD=SuperAdmin123!
SUPER_ADMIN_NOMBRE=Super Admin

# Datos de prueba (productos demo, ventas, reservaciones, usuarios demo *.demo@elohim.gt con password Demo123!)
SEED_DATA=true

# Configuración de Pasarela de Pagos (Stripe)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
Stripe__DefaultCurrency=gtq

# Connection String Override (opcional, en Docker se utiliza el valor de appsettings.json)
# ConnectionStrings__DefaultConnection=Host=localhost;Port=5433;Database=dmhub;Username=postgres;Password=postgres

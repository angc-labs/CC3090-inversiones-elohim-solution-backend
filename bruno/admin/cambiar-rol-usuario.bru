meta {
  name: Cambiar rol usuario (super admin)
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/api/admin/usuarios/{{usuarioId}}/rol
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "rol": "cajero",
    "tipoCliente": "particular"
  }
}

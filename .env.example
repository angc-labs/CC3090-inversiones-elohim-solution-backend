# Copiar a backend/.env (usado por docker-compose: env_file: ./backend/.env)

ASPNETCORE_ENVIRONMENT=Development

# Super admin (se crea al iniciar si no existe)
SUPER_ADMIN_EMAIL=superadmin@elohim.gt
SUPER_ADMIN_PASSWORD=SuperAdmin123!
SUPER_ADMIN_NOMBRE=Super Admin

# Datos de prueba: productos demo, ventas, reservaciones, usuarios *.demo@elohim.gt (Demo123!)
SEED_DATA=true

